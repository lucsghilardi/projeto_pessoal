APP_NAME=projeto_pessoal
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8000

APP_LOCALE=pt_BR
APP_FALLBACK_LOCALE=pt_BR
APP_FAKER_LOCALE=pt_BR

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# Banco de dados (PostgreSQL em container Docker)
DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=projeto_pessoal
DB_USERNAME=projeto_pessoal
DB_PASSWORD=secret

# Credenciais consumidas pelo container postgres (docker-compose)
POSTGRES_DB=projeto_pessoal
POSTGRES_USER=projeto_pessoal
POSTGRES_PASSWORD=secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=local
QUEUE_CONNECTION=sync
CACHE_STORE=database

# Leitura de comprovantes por IA (Anthropic Claude com visão)
ANTHROPIC_API_KEY=
ANTHROPIC_RECEIPT_MODEL=claude-sonnet-4-6

MAIL_MAILER=log
MAIL_FROM_ADDRESS="nao-responda@example.com"
MAIL_FROM_NAME="${APP_NAME}"

# Autenticacao JWT (tymon/jwt-auth) — gere com: php artisan jwt:secret
JWT_SECRET=
JWT_TTL=60

# Usuario administrador inicial (criado pela migration de seed).
# A senha precisa ter no minimo 12 caracteres.
ADMIN_NAME=
ADMIN_EMAIL=
ADMIN_PASSWORD=
